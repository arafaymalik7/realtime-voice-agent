# Copy to .env and fill in real values. NEVER commit .env.

# --- Provider API keys (all have free tiers) ---
DEEPGRAM_API_KEY=your_deepgram_key_here
GEMINI_API_KEY=your_gemini_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# --- Server ---
PORT=3000
# No mic audio for this many ms -> the session is closed. Default 300000 (5 min).
# IDLE_TIMEOUT_MS=300000

# --- Agent config (per-business persona; multi-tenant lookup is on the roadmap) ---
# AGENT_BUSINESS_NAME=Downtown Dental
# AGENT_PERSONA=You are warm, efficient, and never pushy.
# AGENT_TIMEZONE=America/New_York
# AGENT_SLOTS=10:00,11:30,14:30,16:00
# ElevenLabs voice id (defaults to premade "Sarah")
# TTS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Set to 1 to log user transcripts / replies (PII — keep off in production)
DEBUG_TRANSCRIPTS=0
